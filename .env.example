# App
# Local:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Producción (Vercel): OBLIGATORIO para sitemap/robots/canonical correctos en Search Console.
# Usa tu dominio público exacto (www o apex), ej. https://www.listingboost.es
# Si falta, el sitemap puede salir con *.vercel.app y Google marcará «URL no permitida».
# NEXT_PUBLIC_SITE_URL es alias opcional de la misma URL.
# Email único de contacto (footer, /contacto, términos, privacidad, cookies, Enterprise en precios).
NEXT_PUBLIC_CONTACT_EMAIL=info@listingboost.es
#
# Formulario /contacto vía Resend (servidor). Crea API key en resend.com y verifica dominio (SPF/DKIM).
# RESEND_FROM_EMAIL debe ser una dirección del dominio verificado, ej. ListingBoost <contact@listingboost.es>
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Opcional: bandeja distinta a NEXT_PUBLIC_CONTACT_EMAIL (si no, se usa el email público).
# CONTACT_TO_EMAIL=info@listingboost.es
#
# Email de bienvenida al registrarse (plantilla publicada en Resend). Por defecto: alias listing-boost-welcome.
# Variables enviadas: { name }. Si la plantilla falla, se envía un HTML de respaldo.
# RESEND_WELCOME_TEMPLATE_ID=listing-boost-welcome
# RESEND_WELCOME_SUBJECT=Bienvenido a ListingBoost
# Opcional: si lo rellenas y CONTACT está vacío, se usa como respaldo (misma dirección está bien).
NEXT_PUBLIC_ENTERPRISE_CONTACT_EMAIL=info@listingboost.es
# Opcional: razón social / titular para textos legales (términos, privacidad)
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=Tu Empresa SL

# Sesión (Auth.js JWT): por defecto 15 min de inactividad; cada petición renueva el reloj.
# AUTH_SESSION_MAX_AGE_SECONDS=900

# Base de datos PostgreSQL (obligatorio para registro/login local)
#
# Prisma CLI solo lee .env por defecto; este proyecto usa npm run db:push (carga .env.local vía dotenv-cli).
#
# Supabase — API JavaScript (opcional; Prisma sigue usando DATABASE_URL de Postgres)
NEXT_PUBLIC_SUPABASE_URL=https://TUREF.supabase.co
# Preferente (dashboard nuevo): sb_publishable_…
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Legado: JWT anon (eyJ…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Servidor: sb_secret_… o JWT service_role
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — Postgres (Prisma / NextAuth adapter)
# - Las claves sb_publishable_ / sb_secret_ NO son DATABASE_URL (son API REST/JS).
# - Si al iniciar sesión ves error «Configuration» y en la terminal «Can't reach database server» (P1001):
#   tu red no llega a la conexión DIRECTA (IPv6). Abre Supabase → tu proyecto → Connect →
#   «Session pooler» y copia la URI COMPLETA (usuario suele ser postgres.TUREF, host aws-0-…pooler…).
#   Pégala como DATABASE_URL. Diagnóstico: npm run db:check
# - No inventes la región (eu-central-1, etc.): debe coincidir con tu proyecto o verás «Tenant or user not found».
# - Opción de pago: Project Settings → Add-ons → IPv4 para usar db.*.supabase.co:5432 desde redes solo IPv4.
# - Tras cambiar URL: npm run db:check && npm run dev
#
# Ejemplo directo (solo si tu red tiene IPv6 o add-on IPv4):
DATABASE_URL="postgresql://postgres:PASSWORD@db.TUREF.supabase.co:5432/postgres?schema=public&sslmode=require"
# En la práctica en local suele hacer falta la URI del Connect → Session pooler (pégala tal cual):
# DATABASE_URL="postgresql://postgres.TUREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"
#
# Si el pooler sigue fallando («Tenant or user not found») pero necesitas desarrollar ya: Postgres local
#   docker compose up -d
#   DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/listingboost?schema=public"
#   npm run db:push && npm run db:check

# Auth.js / NextAuth v5
# Obligatorio en runtime en producción. En local, si falta, el dev server usa un secreto temporal (ver lib/auth-secret.ts).
# Vercel: Project → Settings → Environment Variables → AUTH_SECRET para Production (marca también para
# "Build" si existe la opción, o deja el valor en "All environments"). Sin esto, login/sesión fallan en vivo.
AUTH_SECRET="genera-un-secreto-largo-aleatorio"
# Alias reconocido por algunos despliegues:
# NEXTAUTH_SECRET=
# Base pública de la app (sin barra final). En local: http://localhost:3000
AUTH_URL=http://localhost:3000
#
# --- Vercel + Google OAuth (error 400 redirect_uri_mismatch) ---
# 1) En Vercel → Environment Variables → Production, define AUTH_URL exactamente igual que la URL del navegador:
#    https://www.listingboost.es   (o https://listingboost.es si así entras; www y apex son distintos para OAuth)
# 2) En Google Cloud → APIs y servicios → Credenciales → tu cliente OAuth (Web) →
#    «URI de redirección autorizadas», añade UNA línea por dominio que uses:
#    https://www.listingboost.es/api/auth/callback/google
#    https://listingboost.es/api/auth/callback/google
#    (y si pruebas en Vercel: https://TU-PROYECTO.vercel.app/api/auth/callback/google)
# 3) «Orígenes JavaScript autorizados» deben incluir el mismo origen (solo esquema+host+puerto si aplica), ej.:
#    https://www.listingboost.es
# 4) Redeploy tras cambiar variables.

# Emails de administrador (coma-separados, sin espacios problemáticos). Obtienen rol ADMIN al iniciar sesión.
# Tras el primer login, aparece el enlace "Administración" y acceso a /admin
ADMIN_EMAILS=tu@email.com

# --- Google OAuth (opcional) ---
# Copia a .env.local (Next.js no lee .env.example). En Google Cloud Console autoriza:
#   {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# DeepSeek (servidor)
DEEPSEEK_API_KEY=

# UploadThing
UPLOADTHING_TOKEN=

# Pagos Stripe: activos por defecto (checkout, portal, créditos). Solo pon false para desactivar en emergencia.
# NEXT_PUBLIC_COMMERCE_ENABLED=false

# Stripe — OBLIGATORIO en Vercel: STRIPE_SECRET_KEY (Developers → API keys → Secret key, sk_live_… o sk_test_…).
# Sin esta clave, checkout y créditos fallan aunque tengas los Price ID bien puestos.
#
# Catálogo: con .env.local cargado, `npm run stripe:seed` (imprime IDs) o `npm run stripe:seed:write`
# (crea/reutiliza precios en test o live según sk_test_ / sk_live_ y actualiza STRIPE_PRICE_ID_* en .env.local).
#
# Asistente del Dashboard («¿Cómo quieres empezar a cobrar?»): no lo sustituye el código; es solo onboarding.
# No marques solo «Envía facturas» / enlaces manuales como flujo principal: la app cobra con Checkout API
# (suscripciones y créditos). Elige «Integra las API de pagos» o cierra el modal; completa datos del negocio
# si Stripe lo pide. Payment methods (Live): activa Tarjeta para EUR. Suscripciones → las crea Checkout al pagar.
#
STRIPE_SECRET_KEY=
# Opcional: para Stripe.js / Elements en el cliente
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Local: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` → whsec_…
# En el endpoint (Dashboard o CLI) incluye al menos: checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted, invoice.payment_succeeded
# (las renovaciones mensuales actualizan periodo y estado vía subscription.updated / invoice).
#
# Tras el pago, success_url incluye session_id y el dashboard llama POST /api/stripe/complete (respaldo del webhook).
# Activa «Customer portal» en Stripe (Billing) para /api/stripe/portal en Ajustes.
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PRO_PLUS=
# Opcional: si no existe, el checkout Enterprise usa el precio Pro+ y el plan se guarda vía metadata de suscripción.
STRIPE_PRICE_ID_ENTERPRISE=

# Tras cambiar importes en scripts/stripe-seed-catalog.cjs, ejecuta `npm run stripe:seed:write` (Live/Test según sk_).
# Plan Free: crédito extra = 2 €; scan URL gasta 2 créditos por ejecución en la app.
#
# Stripe — créditos extra (precios unitarios, modo pago único; quantity = nº de créditos).
# El checkout elige UN price según el plan del usuario en BD: FREE→CREDIT_FREE, PRO→CREDIT_PRO, etc.
STRIPE_PRICE_ID_CREDIT_FREE=
STRIPE_PRICE_ID_CREDIT_PRO=
STRIPE_PRICE_ID_CREDIT_PRO_PLUS=
# Enterprise puede reutilizar el mismo Price que Pro+ (ver lib/stripe/plan-mapping.ts)
STRIPE_PRICE_ID_CREDIT_ENTERPRISE=

# Límites incluidos/mes (opcional; por defecto: 5 / 120 / 280 / 500)
# FREE_MONTHLY_ANALYSES=5
# PRO_MONTHLY_ANALYSES=120
# PRO_PLUS_MONTHLY_ANALYSES=280
# ENTERPRISE_MONTHLY_ANALYSES=500
# FREE_HISTORY_LIMIT=10
