generator client {
  provider = "prisma-client-js"
}

// Producción (Supabase): usa pooler en modo TRANSACCIÓN + ?pgbouncer=true&connection_limit=1 en DATABASE_URL
// (ver .env.example). Opcional: DIRECT_URL en .env solo si usas `prisma migrate` con directUrl en schema.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  PRO_PLUS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum ProductPlatformTarget {
  WALLAPOP
  EBAY
  SHOPIFY
  GENERIC
  ALL
}

enum UrlPageType {
  HOME
  PRODUCT
  COLLECTION
  BLOG
  CATEGORY
  OTHER
}

enum AccountProfile {
  MARKETPLACE_SELLER
  ECOMMERCE_BRAND
  AGENCY_FREELANCER
  OTHER
}

/** Tipo de titular al registrarse (empresa, autónomo o particular). */
enum AccountKind {
  EMPRESA
  AUTONOMO
  PARTICULAR
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  companyName   String?
  phone         String?
  profileType   AccountProfile?
  accountKind   AccountKind?
  termsAcceptedAt DateTime?
  plan          Plan      @default(FREE)
  role          UserRole  @default(USER)
  /** Consumo del cupo incluido en el mes (se resetea con monthResetAt). */
  analysesThisMonth Int   @default(0)
  /** Créditos comprados aparte; no se resetean al cambiar de mes. */
  bonusCreditsRemaining Int @default(0)
  monthResetAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  productAnalyses ProductAnalysis[]
  urlAudits     UrlAudit[]
  usageEvents   UsageEvent[]
  apiLogs       ApiLog[]
  savedProjects SavedProject[]
  siteVisits    SiteVisit[]
  backgroundJobs BackgroundJob[]
  stripeCheckoutFulfillments StripeCheckoutFulfillment[]
  billingInvoiceRequests    BillingInvoiceRequest[]
  passwordResetTokens       PasswordResetToken[]
  seoMonitorings            SeoMonitoring[]
  blogOptimizations         BlogOptimization[]
  competitorAnalyses        CompetitorAnalysis[]
  contentGenerations        ContentGeneration[]
  serpCompetitorInsightReports SerpCompetitorInsightReport[]
  seoGapReports                 SeoGapReport[]
}

/** Token de un solo uso para restablecer contraseña (email). */
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/** Cola ligera: boost de ficha en segundo plano (planes de pago). */
model BackgroundJob {
  id          String   @id @default(cuid())
  userId      String
  kind        String
  status      String
  title       String
  error       String?  @db.Text
  resultId    String?
  payloadJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String               @id @default(cuid())
  userId               String
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  stripePriceId        String?
  status               SubscriptionStatus   @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StripeCheckoutFulfillment {
  checkoutSessionId String   @id
  userId            String
  kind              String
  /** Créditos añadidos en esta sesión (compra de créditos). */
  creditsAdded      Int      @default(0)
  /** Total cobrado según Stripe (centimos), ej. amount_total. */
  amountTotalCents  Int?
  currency          String?  @db.VarChar(8)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

/** Solicitud de factura con datos fiscales (procesamiento manual o integración futura). */
model BillingInvoiceRequest {
  id                String   @id @default(cuid())
  userId            String
  userEmail         String?
  checkoutSessionId String?
  legalName         String
  taxId             String
  address           String   @db.Text
  notes             String?  @db.Text
  status            String   @default("pending")
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ProductAnalysis {
  id               String                 @id @default(cuid())
  userId           String
  imageUrl         String?
  descriptionInput String?                @db.Text
  platformTarget   ProductPlatformTarget
  language         String
  country          String
  categoryHint     String?
  tone             String
  outputJson       Json
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UrlAudit {
  id              String       @id @default(cuid())
  userId          String
  url             String
  country         String
  keywordHint     String?
  pageType        UrlPageType
  crawlSummaryJson Json
  outputJson      Json
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ApiLog {
  id         String   @id @default(cuid())
  userId     String?
  provider   String
  operation  String
  ok         Boolean
  latencyMs  Int
  message    String?  @db.Text
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model SavedProject {
  id        String   @id @default(cuid())
  userId    String
  name      String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/** Vistas de página (cliente + beacon); visitante anónimo vía visitorKey en localStorage. */
model SiteVisit {
  id         String   @id @default(cuid())
  path       String
  visitorKey String
  userId     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([visitorKey, createdAt])
}

/** Seguimiento de posiciones (planes Pro+; cron diario/semanal). */
model SeoMonitoring {
  id           String   @id @default(cuid())
  userId       String
  url          String
  keyword      String
  cadence      String   @default("weekly")
  active       Boolean  @default(true)
  lastPosition Int?
  lastNote     String?  @db.Text
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots SeoMonitoringSnapshot[]
  insightReports SerpCompetitorInsightReport[]

  @@index([userId, active])
  @@index([nextRunAt])
}

/** Informe SERP premium (vs competidores) guardado para historial y PDF. */
model SerpCompetitorInsightReport {
  id             String   @id @default(cuid())
  userId         String
  monitoringId   String?
  keyword        String
  pageUrl        String   @db.Text
  positionAtRun  Int?
  creditsUsed    Int      @default(0)
  outputJson     Json
  createdAt      DateTime @default(now())

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitoring SeoMonitoring? @relation(fields: [monitoringId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([monitoringId, createdAt])
}

/** SEO Gap Finder AI: SERP real + crawl competidores + oportunidades priorizadas (Pro+ / Enterprise). */
model SeoGapReport {
  id          String   @id @default(cuid())
  userId      String
  keyword     String
  domain      String?
  country     String   @default("es")
  language    String   @default("es")
  creditsUsed Int      @default(0)
  /** Dedupe de caché 24h por usuario (hash keyword+domain+gl+hl). */
  cacheKey    String?
  outputJson  Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, cacheKey])
}

model SeoMonitoringSnapshot {
  id           String   @id @default(cuid())
  monitoringId String
  position     Int?
  serpTitle    String?  @db.Text
  rawJson      Json?
  createdAt    DateTime @default(now())

  monitoring SeoMonitoring @relation(fields: [monitoringId], references: [id], onDelete: Cascade)

  @@index([monitoringId, createdAt])
}

model BlogOptimization {
  id          String   @id @default(cuid())
  userId      String
  inputText   String   @db.Text
  outputJson  Json
  creditsUsed Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CompetitorAnalysis {
  id          String   @id @default(cuid())
  userId      String
  urlA        String
  urlB        String
  outputJson  Json
  creditsUsed Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ContentGeneration {
  id          String   @id @default(cuid())
  userId      String
  keyword     String
  contentType String
  outputJson  Json
  creditsUsed Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
